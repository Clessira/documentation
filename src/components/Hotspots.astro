---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Spot {
  /** Top-left X in % of image width. */
  x: number;
  /** Top-left Y in % of image height. */
  y: number;
  /** Width in % of image width. */
  w: number;
  /** Height in % of image height. */
  h: number;
  label: string | number;
  /** Optional override; otherwise picked from the palette by index. */
  color?: string;
}

interface Props {
  src: ImageMetadata;
  alt: string;
  spots: Spot[];
  maxWidth?: string;
}

const { src, alt, spots, maxWidth = '420px' } = Astro.props;

const lang = Astro.url.pathname.startsWith('/en/') ? 'en' : 'de';
const labels = {
  de: { show: 'Markierungen einblenden', hide: 'Markierungen ausblenden' },
  en: { show: 'Show markers', hide: 'Hide markers' },
}[lang];

const PALETTE = [
  '#4f9dff', // brand blue
  '#b48cff', // brand purple
  '#5ed3a3', // teal
  '#ffb454', // amber
  '#ff7eb6', // pink
  '#7dd3fc', // sky
  '#fde047', // yellow
];

const overlayId = `hotspots-overlay-${Math.random().toString(36).slice(2, 8)}`;
---

<figure class="hotspots" data-hotspots style={`--hotspots-max: ${maxWidth};`}>
  <div class="hotspots__bar">
    <button
      type="button"
      class="hotspots__toggle"
      aria-pressed="true"
      aria-controls={overlayId}
      data-toggle
    >
      <span data-on>{labels.hide}</span>
      <span data-off hidden>{labels.show}</span>
    </button>
  </div>
  <div class="hotspots__wrap">
    <Image src={src} alt={alt} />
    <div class="hotspots__overlay" id={overlayId} data-overlay>
      {spots.map(({ x, y, w, h, label, color }, i) => {
        const c = color ?? PALETTE[i % PALETTE.length];
        return (
          <span
            class="hotspots__box"
            style={`left:${x}%; top:${y}%; width:${w}%; height:${h}%; --hs:${c};`}
            aria-hidden="true"
          >
            <span class="hotspots__tag">{label}</span>
          </span>
        );
      })}
    </div>
  </div>
</figure>

<style>
  .hotspots { margin: 1rem 0; }
  .hotspots__bar {
    max-width: var(--hotspots-max, 420px);
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.35rem;
  }
  .hotspots__toggle {
    appearance: none;
    background: transparent;
    border: 1px solid var(--sl-color-gray-5, #555);
    color: inherit;
    border-radius: 999px;
    font: inherit;
    font-size: 0.75rem;
    padding: 0.15rem 0.7rem;
    cursor: pointer;
    line-height: 1.3;
  }
  .hotspots__toggle:hover { border-color: var(--cl-brand, #4f9dff); }
  .hotspots__toggle:focus-visible {
    outline: 2px solid var(--cl-brand, #4f9dff);
    outline-offset: 2px;
  }
  .hotspots__wrap {
    position: relative;
    display: inline-block;
    max-width: var(--hotspots-max, 420px);
    width: 100%;
    line-height: 0;
  }
  .hotspots__wrap :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    display: block;
  }
  .hotspots__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hotspots__overlay[hidden] { display: none; }
  .hotspots__box {
    position: absolute;
    border: 1px solid var(--hs, #4f9dff);
    border-radius: 0.25rem;
    background: color-mix(in srgb, var(--hs, #4f9dff) 10%, transparent);
    box-sizing: border-box;
  }
  .hotspots__tag {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(-35%, -35%);
    min-width: 0.95rem;
    height: 0.95rem;
    padding: 0 0.25rem;
    border-radius: 999px;
    background: var(--hs, #4f9dff);
    color: #fff;
    font: 600 0.65rem/0.95rem var(--sl-font, system-ui);
    text-align: center;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
  }
  @media (forced-colors: active) {
    .hotspots__box { border-color: CanvasText; background: transparent; }
    .hotspots__tag { background: CanvasText; color: Canvas; }
    .hotspots__toggle { border-color: CanvasText; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-hotspots]').forEach((root) => {
    const toggle = root.querySelector<HTMLButtonElement>('[data-toggle]');
    const overlay = root.querySelector<HTMLElement>('[data-overlay]');
    const on = root.querySelector<HTMLElement>('[data-on]');
    const off = root.querySelector<HTMLElement>('[data-off]');
    if (!toggle || !overlay || !on || !off) return;

    const apply = (visible: boolean) => {
      toggle.setAttribute('aria-pressed', String(visible));
      overlay.toggleAttribute('hidden', !visible);
      on.toggleAttribute('hidden', !visible);
      off.toggleAttribute('hidden', visible);
    };

    toggle.addEventListener('click', () => {
      const pressed = toggle.getAttribute('aria-pressed') === 'true';
      apply(!pressed);
    });
  });
</script>
